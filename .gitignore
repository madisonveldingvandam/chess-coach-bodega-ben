.DS_Store
.venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
*.egg-info/

# Runtime-owned cache/results. Keep the directories documented, not the data.
data/*
!data/.gitkeep

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/public/data/*.json
!frontend/public/data/.gitkeep

# Local environment
.env
.env.*
!.env.example
